<script>
const slides=document.querySelectorAll('.slide');
const N=slides.length;
let cur=0;

function buildDots(){
  const d=document.getElementById('dots');
  for(let i=0;i<N;i++){
    const el=document.createElement('div');
    el.className='dot'+(i===0?' active':'');
    el.onclick=()=>go(i);
    d.appendChild(el);
  }
}

function refresh(){
  document.getElementById('prog').style.width=((cur+1)/N*100)+'%';
  document.getElementById('ctr').textContent=(cur+1)+' / '+N;
  document.querySelectorAll('.dot').forEach((d,i)=>d.classList.toggle('active',i===cur));
}

function go(idx){
  if(idx<0||idx>=N||idx===cur)return;
  slides[cur].classList.remove('active');
  slides[cur].classList.add('exit-up');
  const prev_cur=cur;
  cur=idx;
  setTimeout(()=>slides[prev_cur].classList.remove('exit-up'),600);
  slides[cur].classList.add('active');
  refresh();
}

function next(){go(Math.min(cur+1,N-1));}
function prev(){go(Math.max(cur-1,0));}

document.addEventListener('keydown',e=>{
  if(['ArrowRight','ArrowDown',' '].includes(e.key)){e.preventDefault();next();}
  if(['ArrowLeft','ArrowUp'].includes(e.key)){e.preventDefault();prev();}
});

let tx=0;
document.addEventListener('touchstart',e=>tx=e.touches[0].clientX,{passive:true});
document.addEventListener('touchend',e=>{
  const d=tx-e.changedTouches[0].clientX;
  if(Math.abs(d)>60){d>0?next():prev();}
},{passive:true});

buildDots();refresh();
</script>
</body>
</html>
